{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=temperature_monitoring;Username=tms_user;Password=tms_password"
  },
  "FaultTolerance": {
    "RequiredActiveSensors": 5,
    "InactivityTimeoutSeconds": 10,
    "BlockDurationSeconds": 30,
    "WatchdogIntervalSeconds": 2
  },
  "NotificationService": {
    "BaseUrl": "http://localhost:5117",
    "Enabled": true
  },
  "SensorThresholds": [
    { "SensorId": "sensor-01", "ThresholdPriority1": 45, "ThresholdPriority2": 50, "ThresholdPriority3": 58 },
    { "SensorId": "sensor-02", "ThresholdPriority1": 48, "ThresholdPriority2": 54, "ThresholdPriority3": 62 },
    { "SensorId": "sensor-03", "ThresholdPriority1": 46, "ThresholdPriority2": 52, "ThresholdPriority3": 60 },
    { "SensorId": "sensor-04", "ThresholdPriority1": 47, "ThresholdPriority2": 53, "ThresholdPriority3": 61 },
    { "SensorId": "sensor-05", "ThresholdPriority1": 49, "ThresholdPriority2": 55, "ThresholdPriority3": 63 },
    { "SensorId": "sensor-06", "ThresholdPriority1": 44, "ThresholdPriority2": 51, "ThresholdPriority3": 59 },
    { "SensorId": "sensor-07", "ThresholdPriority1": 50, "ThresholdPriority2": 56, "ThresholdPriority3": 64 },
    { "SensorId": "sensor-08", "ThresholdPriority1": 52, "ThresholdPriority2": 58, "ThresholdPriority3": 66 }
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
